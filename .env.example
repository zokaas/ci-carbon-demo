# =============================================================================
# ci-carbon-demo – environment variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Run the analysis:
#   node --env-file=.env scripts/analyze_results.mjs
#
# The --env-file flag is built into Node.js 20.6+ — no extra packages needed.
#
# WARNING: Never commit .env to version control — it is already in .gitignore
# =============================================================================

# GitHub repository (format: username/repo-name)
REPO=zokaas/ci-carbon-demo

# =============================================================================
# Simulation time windows
# Fill in after running each simulation script — use the timestamps it prints
# Format: ISO 8601 in UTC, e.g. 2026-04-29T22:09:59Z
# =============================================================================

# Part A: CI optimisation simulation (simulate_commits.sh)
SIM_A_START=
SIM_A_END=

# Part B: Docker comparison simulation (simulate_docker_commits.sh)
SIM_B_START=
SIM_B_END=

# =============================================================================
# Branch names — defaults work if you use the standard branch names
# Change only if you use different branch names:
#   1. Update the value below
#   2. Update the branches filter in the corresponding workflow files
# =============================================================================

CI_BRANCH=ci-sim
DOCKER_BRANCH=docker-sim
